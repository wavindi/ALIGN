#!/usr/bin/env bash
set -Eeuo pipefail

APP_NAME="ALIGN Operational Suite"
APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST="${HOST:-0.0.0.0}"
PORT="${PORT:-3000}"
SERVICE_MODE=0
START_APP=1

usage() {
  cat <<USAGE
Usage: ./setup [options]

Installs and starts ${APP_NAME} on a Linux server without requiring a database.

Options:
  --service       Install and start ALIGN as a systemd service.
  --no-start      Install and build without starting.
  --help          Show this help.

Environment:
  HOST            Bind address. Default: 0.0.0.0
  PORT            Web port. Default: 3000

Examples:
  ./setup
  PORT=4000 ./setup
  ./setup --service
USAGE
}

log() {
  printf '\n[%s] %s\n' "ALIGN" "$*"
}

fail() {
  printf '\n[ALIGN] ERROR: %s\n' "$*" >&2
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

sudo_cmd() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  elif command_exists sudo; then
    sudo "$@"
  else
    fail "This step needs root permissions. Install sudo or run as root."
  fi
}

node_supported() {
  command_exists node || return 1
  node -e '
    const [major, minor] = process.versions.node.split(".").map(Number);
    const ok = major > 20 || (major === 20 && minor >= 9);
    process.exit(ok ? 0 : 1);
  ' >/dev/null 2>&1
}

install_system_packages() {
  if command_exists apt-get; then
    log "Installing Linux prerequisites"
    sudo_cmd apt-get update
    sudo_cmd apt-get install -y ca-certificates curl gnupg
  else
    log "apt-get was not found. Make sure Node.js 20.9+ and npm are installed."
  fi
}

install_node_if_needed() {
  if node_supported; then
    log "Node.js $(node -v) is supported"
    return
  fi

  if ! command_exists apt-get; then
    fail "Install Node.js 20.9 or newer, then run ./setup again."
  fi

  log "Installing Node.js 22 LTS"
  sudo_cmd apt-get update
  sudo_cmd apt-get install -y ca-certificates curl gnupg
  curl -fsSL https://deb.nodesource.com/setup_22.x | sudo_cmd bash -
  sudo_cmd apt-get install -y nodejs

  node_supported || fail "Node.js was installed but is still not compatible. Need Node.js 20.9+."
  log "Node.js $(node -v) is ready"
}

install_app() {
  cd "$APP_DIR"

  log "Installing npm dependencies"
  if [ -f "package-lock.json" ]; then
    npm ci
  else
    npm install
  fi

  log "Building production bundle"
  npm run build
}

local_ip() {
  if command_exists hostname; then
    hostname -I 2>/dev/null | awk '{print $1}'
  fi
}

wait_for_app() {
  local url="http://127.0.0.1:${PORT}"

  for _ in $(seq 1 40); do
    if command_exists curl && curl -fsS "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done

  return 1
}

print_urls() {
  local ip
  ip="$(local_ip || true)"

  log "ALIGN is running"
  printf 'Local URL:   http://127.0.0.1:%s\n' "$PORT"
  if [ -n "$ip" ]; then
    printf 'Network URL: http://%s:%s\n' "$ip" "$PORT"
  else
    printf 'Network URL: http://SERVER_IP:%s\n' "$PORT"
  fi
  printf '\nLogin users: counter / finance / admin\n'
  printf 'Default password: align\n'
}

open_browser_if_possible() {
  if [ -n "${DISPLAY:-}" ] && command_exists xdg-open; then
    xdg-open "http://127.0.0.1:${PORT}" >/dev/null 2>&1 || true
  fi
}

start_foreground() {
  cd "$APP_DIR"
  log "Starting ALIGN on ${HOST}:${PORT}"
  npx next start -H "$HOST" -p "$PORT" &
  local server_pid=$!

  cleanup() {
    kill "$server_pid" >/dev/null 2>&1 || true
  }
  trap cleanup INT TERM

  if wait_for_app; then
    print_urls
    open_browser_if_possible
  else
    cleanup
    fail "The app did not respond on port ${PORT}. Check the console output above."
  fi

  wait "$server_pid"
}

install_service() {
  command_exists systemctl || fail "systemd was not found. Run ./setup without --service instead."

  log "Installing systemd service"
  sudo_cmd tee /etc/systemd/system/align.service >/dev/null <<SERVICE
[Unit]
Description=ALIGN Operational Suite
After=network.target

[Service]
Type=simple
WorkingDirectory=${APP_DIR}
Environment=NODE_ENV=production
Environment=HOST=${HOST}
Environment=PORT=${PORT}
ExecStart=/bin/bash -lc 'cd "${APP_DIR}" && exec npx next start -H "${HOST}" -p "${PORT}"'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
SERVICE

  sudo_cmd systemctl daemon-reload
  sudo_cmd systemctl enable align.service
  sudo_cmd systemctl restart align.service

  if command_exists ufw && sudo_cmd ufw status | grep -qi "Status: active"; then
    sudo_cmd ufw allow "${PORT}/tcp" >/dev/null || true
  fi

  if wait_for_app; then
    print_urls
    log "Service commands: sudo systemctl status align | sudo journalctl -u align -f"
  else
    sudo_cmd systemctl status align.service --no-pager || true
    fail "The align.service did not respond on port ${PORT}."
  fi
}

for arg in "$@"; do
  case "$arg" in
    --service)
      SERVICE_MODE=1
      ;;
    --no-start)
      START_APP=0
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      fail "Unknown option: $arg"
      ;;
  esac
done

log "Setting up ${APP_NAME}"
install_system_packages
install_node_if_needed
install_app

if [ "$START_APP" -eq 0 ]; then
  log "Setup complete. Start later with: npm start"
elif [ "$SERVICE_MODE" -eq 1 ]; then
  install_service
else
  start_foreground
fi
